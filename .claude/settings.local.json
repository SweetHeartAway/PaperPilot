{
  "hooks": {
    "onFileUpdate": [
      {
        "glob": "backend/**/*.py",
        "run": "cd /e/paper-manager-project/backend && PYTHONPATH=. python -m pytest tests/ -x --tb=short 2>&1",
        "description": "Backend 代码变更后自动运行 pytest，失败时 Claude 自动修复直到 PASS"
      }
    ],
    "onPreCommit": [
      {
        "glob": "backend/**/*.py",
        "run": "cd /e/paper-manager-project/backend && PYTHONPATH=. python -m pytest tests/ -x --tb=short 2>&1",
        "description": "Backend commit 前自动运行 pytest"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git init *)",
      "Bash(git commit *)",
      "Bash(pip install *)",
      "Bash(pip3 --version)",
      "Bash(python3.12 --version)",
      "Bash(PYTHONPATH=\"/e/paper-manager-project/backend\" python *)",
      "Bash(PYTHONPATH=. python -c \"from main import app; print\\('App loaded successfully'\\)\")",
      "Bash(PYTHONPATH=. uvicorn main:app --host 0.0.0.0 --port 8000 --reload)",
      "Bash(pip --version)",
      "Bash(pip list *)",
      "Bash(PYTHONPATH=. python -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload)",
      "Bash(curl *)",
      "Bash(chmod +x *)",
      "Bash(PYTHONPATH=. alembic revision --autogenerate -m \"add file fields to paper\")",
      "Bash(PYTHONPATH=. python -m alembic revision --autogenerate -m \"add file fields to paper\")",
      "Bash(rm -f E:/paper-manager-project/backend/paperpilot.db E:/paper-manager-project/backend/tests/test_paperpilot.db)",
      "Bash(PYTHONPATH=. python -m alembic revision --autogenerate -m \"initial schema\")",
      "Bash(PYTHONPATH=. python -m alembic upgrade head)",
      "Bash(PYTHONPATH=. python -c ' *)",
      "Bash(PYTHONPATH=. python -c \"from main import app; print\\('OK'\\)\")",
      "Bash(PYTHONPATH=. python -m pytest tests/test_auth.py tests/test_users.py -v)",
      "Bash(PYTHONPATH=. python -m pytest tests/test_papers.py -v)",
      "Bash(PYTHONPATH=. python -m pytest tests/ -v)",
      "Bash(mkdir -p .claude/skills/review-code .claude/skills/api-design)",
      "Bash(mv .claude/skills/review-code.md .claude/skills/review-code/SKILL.md)",
      "Bash(mv .claude/skills/api-design.md .claude/skills/api-design/SKILL.md)",
      "Bash(PYTHONPATH=. python -m pytest tests/test_users.py -v)",
      "Bash(python *)",
      "Bash(PYTHONPATH=backend python *)",
      "Bash(git push *)",
      "Bash(PYTHONPATH=. python -m pytest tests/test_tags.py -v)",
      "Bash(PYTHONPATH=. python -m pytest tests/test_auth.py -v)",
      "Bash(npm --version)",
      "Bash(npm create *)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(git add *)",
      "Bash(xargs wc -l)",
      "Bash(pre-commit install *)",
      "Bash(PYTHONPATH=. python -m pytest tests/ -v --tb=short)",
      "Bash(bash E:/paper-manager-project/.claude/hooks/MessageDisplay)",
      "Bash(echo \"Exit code: $?\")",
      "Bash(cmd.exe /c \"E:\\\\paper-manager-project\\\\.claude\\\\hooks\\\\MessageDisplay.bat\")",
      "Bash(git check-ignore *)",
      "Bash(grep -n \"claude\" .gitignore)",
      "Bash(git ls-files *)",
      "Bash(cd /e/paper-manager-project/backend && PYTHONPATH=. python -m pytest *)"
    ]
  }
}
